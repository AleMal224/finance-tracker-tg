# ──────────────────────────────────────────────────────────
# 🤖 Finance Tracker Bot — переменные окружения
# ──────────────────────────────────────────────────────────
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Токен бота от @BotFather (обязательно!)
BOT_TOKEN=1234567890:AABBccDDeeffGGhhIIjjKKllMMnnOOppQQ

# HTTPS URL твоего задеплоенного мини-аппа (обязательно!)
# Примеры:
#   Vercel:   https://finance-tracker.vercel.app
#   Ngrok:    https://xxxx-xx-xx-xx.ngrok-free.app
#   Railway:  https://finance-tracker.up.railway.app
APP_URL=https://YOUR_APP_URL_HERE

# Режим работы бота:
#   false = polling (локальная разработка, не нужен сервер)
#   true  = webhook (продакшн на сервере с HTTPS)
USE_WEBHOOK=false

# Порт для webhook-сервера (только если USE_WEBHOOK=true)
PORT=3000
